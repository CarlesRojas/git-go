{
    "name": "git-go",
    "displayName": "Git Go",
    "publisher": "pinya",
    "author": {
        "name": "Carles Rojas",
        "email": "carlesrojas@outlook.com"
    },
    "description": "Visual representation of your Git repository, with actions to manage commits, branches, stashes, and tags.",
    "version": "1.0.0",
    "engines": {
        "vscode": "^1.116.0"
    },
    "galleryBanner": {
        "color": "#1b1f23",
        "theme": "dark"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "git",
        "graph",
        "github",
        "push",
        "commit",
        "branch",
        "stash",
        "tag",
        "diff",
        "action",
        "visualise",
        "pinya"
    ],
    "icon": "icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/CarlesRojas/git-go"
    },
    "bugs": {
        "url": "https://github.com/CarlesRojas/git-go/issues"
    },
    "activationEvents": [
        "*"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "git-go.openGitGraph",
                "title": "Git Go - Open Graph"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Git Go",
            "properties": {
                "git-go.graph.rounded": {
                    "type": "boolean",
                    "default": true,
                    "description": "Use rounded corners for all commit graph elements."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "pnpm run build",
        "build": "pnpm run compile && cd panel && pnpm run build",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "dev": "pnpm run build && code ."
    },
    "devDependencies": {
        "@types/node": "22.x",
        "@types/vscode": "^1.116.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0"
    }
}
