{
    "name": "git-go",
    "displayName": "git-go",
    "description": "A VS Code extension that adds a status bar button to open a React+Tailwind git graph webview.",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.116.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "*"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "git-go.openGitGraph",
                "title": "Git Go - Open Graph"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "pnpm run build",
        "build": "pnpm run compile && cd panel && pnpm run build",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "dev": "pnpm run build && code ."
    },
    "devDependencies": {
        "@types/node": "22.x",
        "@types/vscode": "^1.116.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0"
    }
}
